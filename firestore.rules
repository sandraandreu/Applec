rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica que el usuario autenticado pertenece al grupo solicitado
    function isMemberOfGroup(groupId) {
      return isAuthenticated() && myProfile().get('groupId', null) == groupId;
    }

    // Verifica que el usuario es admin del grupo
    function isAdminOfGroup(groupId) {
      return isMemberOfGroup(groupId) && myProfile().get('role', '') == 'admin';
    }

    // Verifica que el usuario es organizer o admin del grupo
    function isOrganizerOrAdmin(groupId) {
      return isMemberOfGroup(groupId) &&
             myProfile().get('role', '') in ['admin', 'organizer'];
    }

    // ─── Usuarios ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Solo el propio usuario puede leer su perfil
      allow get: if isAuthenticated() && request.auth.uid == userId;

      // Queries de lista restringidas al propio grupo
      allow list: if isAuthenticated() && resource.data.groupId == myProfile().groupId;

      // Crear perfil propio en el registro
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Actualizar perfil propio — no se puede cambiar groupId una vez asignado
      allow update: if isAuthenticated() && request.auth.uid == userId &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['groupId']) ||
          !resource.data.keys().hasAll(['groupId']) ||
          resource.data.groupId == null
        );

      // Admin puede aprobar o rechazar solicitudes de unión al grupo
      allow update: if isAuthenticated() &&
        resource.data.get('pendingJoinGroupId', null) != null &&
        isAdminOfGroup(resource.data.get('pendingJoinGroupId', null)) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['groupId', 'role', 'joinAccepted', 'joinRejected', 'pendingJoinGroupId']);
    }

    // ─── Grupos ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      // Leer un grupo concreto: solo miembros
      allow get: if isMemberOfGroup(groupId);
      // Queries (ej. buscar por inviteCode): cualquier usuario autenticado
      allow list: if isAuthenticated();

      // Cualquier usuario autenticado puede crear un grupo
      allow create: if isAuthenticated();

      // Solo admins pueden modificar el grupo (nombre, código de invitación, miembros)
      allow update: if isAdminOfGroup(groupId);

      // Los grupos nunca se eliminan
      allow delete: if false;

      // ─── Eventos ─────────────────────────────────────────────────────────────
      match /events/{eventId} {
        // Solo miembros del grupo pueden ver los eventos
        allow read: if isMemberOfGroup(groupId);

        // Solo organizers y admins pueden crear, editar y borrar eventos
        allow create: if isOrganizerOrAdmin(groupId);
        allow update: if isOrganizerOrAdmin(groupId);
        allow delete: if isOrganizerOrAdmin(groupId);

        // ─── Asistencia ────────────────────────────────────────────────────────
        match /attendances/{attendanceId} {
          // Todos los miembros del grupo pueden ver la asistencia
          allow read: if isMemberOfGroup(groupId);

          // Cada usuario solo puede escribir su propia asistencia
          allow write: if isMemberOfGroup(groupId) && request.auth.uid == attendanceId;
        }
      }

      // ─── Solicitudes de unión ─────────────────────────────────────────────────
      match /joinRequests/{requestId} {
        // Solo admins pueden ver y gestionar solicitudes
        allow read: if isAdminOfGroup(groupId);

        // Cualquier usuario autenticado puede enviar una solicitud
        allow create: if isAuthenticated();

        // Solo admins pueden aprobar o rechazar
        allow update: if isAdminOfGroup(groupId);
        allow delete: if isAdminOfGroup(groupId);
      }

      // ─── Solicitudes aceptadas ───────────────────────────────────────────────
      match /acceptedRequests/{requestId} {
        allow read: if isMemberOfGroup(groupId);
        allow create: if isAdminOfGroup(groupId);
        allow update: if false;
        allow delete: if false;
      }

      // ─── Miembros vinculados (familiares) ─────────────────────────────────────
      match /linkedMembers/{linkedMemberId} {
        allow read: if isMemberOfGroup(groupId);
        allow create: if isMemberOfGroup(groupId) && request.resource.data.ownerUid == request.auth.uid;
        allow update: if isMemberOfGroup(groupId) && resource.data.ownerUid == request.auth.uid;
        allow delete: if isMemberOfGroup(groupId) && resource.data.ownerUid == request.auth.uid;
      }
    }

    // ─── Query global de asistencia ────────────────────────────────────────────
    // Necesario para getMyAttendances() que usa collectionGroup("attendances")
    // Cada usuario solo puede leer sus propios documentos de asistencia
    match /{path=**}/attendances/{attendanceId} {
      allow read: if isAuthenticated() && request.auth.uid == attendanceId;
    }
  }
}
